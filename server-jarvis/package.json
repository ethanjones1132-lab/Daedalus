{
  "name": "server-jarvis",
  "private": true,
  "version": "3.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun --hot ./src/index.ts",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "start": "bun ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "eval": "bun run src/eval/harness.ts",
    "eval:nightly": "bun run src/eval/nightly-semantic-eval.ts",
    "test:gate": "bun test src/eval/harness.test.ts && bun run src/eval/harness.ts"
  },
  "dependencies": {
    "diff": "^9.0.0",
    "gpt-tokenizer": "^3.4.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/diff": "^8.0.0",
    "typescript": "^6.0.3"
  }
}
